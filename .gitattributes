* text=auto eol=lf

# Always treat these as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.pdf binary

# Shell and Python should always be LF, even if local autocrlf says otherwise
*.sh    text eol=lf
*.py    text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
